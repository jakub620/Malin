<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Prototyp: zezwól na HTTP (cleartext) do wszystkich lokalnych adresów IP -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
